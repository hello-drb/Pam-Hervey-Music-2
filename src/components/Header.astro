---
import { siteSettings } from '../data/siteContent';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-cream/90 backdrop-blur-sm">
  <div class="max-w-[1400px] mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-heading text-2xl font-light tracking-wide text-warm-black hover:text-warm-gray transition-colors">
      {siteSettings.title}
    </a>

    <button id="menu-toggle" class="md:hidden p-2 text-warm-black" aria-label="Open Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <nav class="hidden md:flex items-center gap-8">
      <a href="#music" class="text-sm font-light tracking-wider uppercase text-warm-gray hover:text-warm-black transition-colors">Music</a>
      <a href="#about" class="text-sm font-light tracking-wider uppercase text-warm-gray hover:text-warm-black transition-colors">About</a>
      <a href="#contact" class="text-sm font-light tracking-wider uppercase text-warm-gray hover:text-warm-black transition-colors">Contact</a>
    </nav>
  </div>

  <div id="mobile-menu" class="hidden fixed inset-0 bg-cream z-50 flex flex-col items-center justify-center gap-8">
    <button id="menu-close" class="absolute top-4 right-6 p-2 text-warm-black" aria-label="Close Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <a href="#music" class="mobile-nav-link font-heading text-3xl font-light tracking-wide text-warm-black">Music</a>
    <a href="#about" class="mobile-nav-link font-heading text-3xl font-light tracking-wide text-warm-black">About</a>
    <a href="#contact" class="mobile-nav-link font-heading text-3xl font-light tracking-wide text-warm-black">Contact</a>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');
  const links = document.querySelectorAll('.mobile-nav-link');

  toggle?.addEventListener('click', () => menu?.classList.remove('hidden'));
  close?.addEventListener('click', () => menu?.classList.add('hidden'));
  links.forEach(link => link.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
