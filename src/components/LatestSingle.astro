---
import { latestSingle } from '../data/siteContent';
---

<section class="py-20 md:py-32 bg-cream">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="flex flex-col md:flex-row-reverse items-center gap-12 md:gap-20">
      <div class="w-full md:w-1/2 max-w-lg">
        <img src={latestSingle.coverImage} alt={latestSingle.coverAlt} class="w-full shadow-2xl" loading="lazy" />
      </div>
      <div class="w-full md:w-1/2 text-center md:text-left">
        <p class="text-sm font-light tracking-[0.3em] uppercase text-warm-gray mb-4">
          {latestSingle.listenHeading}
        </p>
        <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl font-light uppercase tracking-wide mb-4">
          {latestSingle.title}
        </h2>
        <p class="text-warm-gray font-light text-lg mb-8">{latestSingle.releaseDate}</p>
        <div class="flex items-center justify-center md:justify-start gap-6">
          {latestSingle.streamingLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer"
              class="text-warm-black/70 hover:text-warm-black transition-colors"
              aria-label={`Listen on ${link.platform}`}>
              {link.platform === "Apple Music" ? (
                <svg class="h-10 w-10" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.994 6.124a9.23 9.23 0 0 0-.24-2.19c-.317-1.31-1.062-2.31-2.18-3.043a5.022 5.022 0 0 0-1.877-.726 10.496 10.496 0 0 0-1.564-.15c-.04-.003-.083-.01-.124-.013H5.986c-.152.01-.303.017-.455.026-.747.043-1.49.123-2.193.4-1.336.53-2.3 1.452-2.865 2.78-.192.448-.292.925-.363 1.408-.056.392-.088.785-.1 1.18 0 .032-.007.062-.01.093v12.223c.01.14.017.283.027.424.05.815.154 1.624.497 2.373.65 1.42 1.738 2.353 3.234 2.802.42.127.856.187 1.293.228.555.053 1.11.06 1.667.06h11.03c.525 0 1.048-.034 1.57-.1.823-.106 1.597-.35 2.296-.81a5.046 5.046 0 0 0 1.88-2.207c.186-.42.293-.87.37-1.324.113-.675.138-1.358.137-2.04-.002-3.8 0-7.595-.003-11.393zm-6.423 3.99v5.712c0 .417-.058.827-.244 1.206-.29.59-.76.962-1.388 1.14-.35.1-.706.157-1.07.173-.95.042-1.8-.335-2.22-1.16-.4-.786-.3-1.63.318-2.287.39-.416.9-.65 1.456-.79.383-.097.776-.15 1.163-.227.363-.072.61-.265.7-.635.025-.1.042-.206.042-.31V8.524c0-.36-.136-.56-.49-.6-.354-.043-.71-.063-1.065-.098l-3.17-.318c-.03-.003-.06-.005-.09-.01-.5-.04-.76.19-.81.7-.005.05-.005.1-.005.15v7.86c0 .423-.047.843-.233 1.23-.296.617-.79 1.004-1.45 1.17-.33.082-.67.137-1.01.155-.96.043-1.83-.335-2.24-1.17-.37-.75-.29-1.53.24-2.2.38-.48.9-.7 1.47-.84.39-.1.78-.16 1.17-.23.39-.07.63-.28.72-.67.023-.1.035-.2.035-.3V6.17c0-.3.07-.58.3-.79.18-.17.4-.26.65-.26.05 0 .1 0 .15.01l5.26.53c.39.04.78.08 1.17.14.39.05.67.34.7.74.02.13.01.26.01.4z"/>
                </svg>
              ) : (
                <svg class="h-10 w-10" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
