---
import { latestSingle } from '../data/siteContent';
---

<section class="py-20 md:py-32 bg-cream">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="flex flex-col md:flex-row-reverse items-center gap-12 md:gap-20">
      <div class="w-full md:w-1/2 max-w-lg">
        <img src={latestSingle.coverImage} alt={latestSingle.coverAlt} class="w-full shadow-2xl" loading="lazy" />
      </div>
      <div class="w-full md:w-1/2 text-center md:text-left">
        <p class="text-sm font-light tracking-[0.3em] uppercase text-warm-gray mb-4">
          {latestSingle.listenHeading}
        </p>
        <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl font-light uppercase tracking-wide mb-4">
          {latestSingle.title}
        </h2>
        <p class="text-warm-gray font-light text-lg mb-8">{latestSingle.releaseDate}</p>
        <div class="flex items-center justify-center md:justify-start gap-6">
          {latestSingle.streamingLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer"
              class="opacity-80 hover:opacity-100 transition-opacity"
              aria-label={`Listen on ${link.platform}`}>
              <img src={link.icon} alt={link.platform} class="h-10 w-10 object-contain" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
